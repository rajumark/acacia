## KSP strategy

```kotlin
// CwProcessorProvider.kt
class CwProcessor(val env: SymbolProcessingEnvironment) : SymbolProcessor {

    override fun process(resolver: Resolver): List<KSAnnotated> {

        // 1. find Modifier class in classpath
        val modifierClass = resolver
            .getClassDeclarationByName("androidx.compose.ui.Modifier")

        // 2. find ALL extension functions on Modifier
        //    this includes compose-ui, foundation,
        //    material3, AND the project's own extensions
        val extensions = resolver
            .getAllFiles()
            .flatMap { it.declarations }
            .filterIsInstance<KSFunctionDeclaration>()
            .filter { fn ->
                fn.extensionReceiver
                  ?.resolve()
                  ?.declaration
                  ?.qualifiedName
                  ?.asString() == "androidx.compose.ui.Modifier"
            }

        // 3. generate a CW wrapper for each one
        extensions.forEach { fn ->
            generate(fn)
        }

        return emptyList()
    }
}
```

